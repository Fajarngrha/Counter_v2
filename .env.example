PORT=3010
SESSION_SECRET=ganti-dengan-secret-acak-panjang

# ============================================================
# MQTT — mode lokal (Raspberry Pi + Mosquitto di mesin yang sama)
# ============================================================
# MQTT_BROKER_URL=mqtt://localhost:1883

# ============================================================
# MQTT — HiveMQ Cloud (sesuai production.md bagian 15)
# ============================================================
MQTT_BROKER_URL=mqtts://GANTI_HOSTNAME.hivemq.cloud:8883
MQTT_USERNAME=GANTI_USERNAME_HIVEMQ
MQTT_PASSWORD=GANTI_PASSWORD_HIVEMQ

MQTT_TOPIC=iot/counter/increment
MQTT_COMMAND_TOPIC=iot/counter/command
MQTT_CLIENT_ID=iot-counter-server-prod

# Login dashboard web
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN
