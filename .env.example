PORT=3000
SESSION_SECRET=ganti-dengan-secret-acak

# Lokal (Raspberry Pi + Mosquitto di mesin yang sama)
MQTT_BROKER_URL=mqtt://localhost:1883

# IoT lapangan jauh — broker cloud (contoh)
# MQTT_BROKER_URL=mqtts://xxxx.s1.eu.hivemq.cloud:8883
# MQTT_USERNAME=user-broker-anda
# MQTT_PASSWORD=password-broker-anda

MQTT_TOPIC=iot/counter/increment
MQTT_CLIENT_ID=iot-counter-server
